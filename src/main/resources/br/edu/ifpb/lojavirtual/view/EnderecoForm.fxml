<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox spacing="15" prefWidth="400" prefHeight="350" style="-fx-padding: 25; -fx-background-color: #FFFFFF;"
      xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.edu.ifpb.lojavirtual.controller.EnderecoFormController">

    <Label text="Cadastrar Endereço" textFill="#00A60E">
        <font><Font name="System Bold" size="20.0"/></font>
    </Label>

    <TextField fx:id="cepField" promptText="CEP" style="-fx-padding: 8; -fx-background-radius: 5;" />

    <TextField fx:id="ruaField" promptText="Rua / Logradouro" style="-fx-padding: 8; -fx-background-radius: 5;" />

    <HBox spacing="10">
        <TextField fx:id="numeroField" promptText="Número" prefWidth="120" style="-fx-padding: 8; -fx-background-radius: 5;" />
        <TextField fx:id="bairroField" promptText="Bairro" HBox.hgrow="ALWAYS" style="-fx-padding: 8; -fx-background-radius: 5;" />
    </HBox>

    <HBox spacing="10">
        <TextField fx:id="cidadeField" promptText="Cidade" HBox.hgrow="ALWAYS" style="-fx-padding: 8; -fx-background-radius: 5;" />
        <TextField fx:id="estadoField" promptText="UF" prefWidth="80" style="-fx-padding: 8; -fx-background-radius: 5;" />
    </HBox>

    <Region VBox.vgrow="ALWAYS" />

    <Button text="Salvar Endereço" onAction="#handleSalvar" maxWidth="Infinity"
            style="-fx-background-color: #00A60E; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 10; -fx-background-radius: 5; -fx-cursor: hand;"/>
</VBox>