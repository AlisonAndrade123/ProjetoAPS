<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="650.0" prefWidth="850.0" style="-fx-background-color: #F4F4F4;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="br.edu.ifpb.lojavirtual.controller.GerenciarCatalogoController">

    <top>
        <HBox alignment="CENTER_LEFT" style="-fx-background-color: #00A60E;">
            <padding>
                <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
            </padding>
            <children>
                <Label text="Gerenciador de Catálogos" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
            </children>
        </HBox>
    </top>

    <center>
        <VBox spacing="20.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>

            <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10;">
                <Label text="Criar Novo Catálogo" textFill="#00A60E">
                    <font><Font name="System Bold" size="16.0" /></font>
                </Label>
                <HBox spacing="15.0" alignment="CENTER_LEFT">
                    <TextField fx:id="txtNomeCatalogo" prefWidth="300.0" promptText="Ex: Ofertas de Inverno" style="-fx-background-radius: 5;" />
                    <Button mnemonicParsing="false" onAction="#criarCatalogo" style="-fx-background-color: #00A60E; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" text="Criar Catálogo" />
                </HBox>
            </VBox>

            <VBox spacing="10.0" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10;" VBox.vgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <Label text="Gerenciar Produtos do Catálogo:" textFill="#00A60E">
                        <font><Font name="System Bold" size="16.0" /></font>
                    </Label>
                    <ComboBox fx:id="cbCatalogos" onAction="#aoSelecionarCatalogo" prefWidth="250.0" promptText="Selecione um catálogo..." style="-fx-background-radius: 5;" />
                </HBox>

                <HBox spacing="15.0" VBox.vgrow="ALWAYS">
                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Produtos Disponíveis" textFill="#555555" />
                        <ListView fx:id="listDisponiveis" prefHeight="250.0" style="-fx-background-radius: 5;" />
                    </VBox>

                    <VBox alignment="CENTER" spacing="15.0">
                        <Button mnemonicParsing="false" onAction="#adicionarProduto" style="-fx-background-color: #00A60E; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Adicionar &gt;&gt;" />
                        <Button mnemonicParsing="false" onAction="#removerProduto" style="-fx-background-color: #F43C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="&lt;&lt; Remover" />
                    </VBox>

                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                        <Label text="Produtos no Catálogo" textFill="#555555" />
                        <ListView fx:id="listVinculados" prefHeight="250.0" style="-fx-background-radius: 5;" />
                    </VBox>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>