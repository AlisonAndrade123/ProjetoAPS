<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="800.0" spacing="15.0" style="-fx-background-color: white; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="br.edu.ifpb.lojavirtual.controller.GerenciarPedidosController">

    <Label text="Gestão de Pedidos (Administrador)" textFill="#00a60e">
        <font><Font name="System Bold" size="22.0" /></font>
    </Label>

    <TableView fx:id="tabelaPedidos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" prefWidth="70.0" text="ID" />
            <TableColumn fx:id="colData" prefWidth="150.0" text="Data" />
            <TableColumn fx:id="colTotal" prefWidth="120.0" text="Total" />
            <TableColumn fx:id="colStatus" prefWidth="180.0" text="Status Atual" />
            <TableColumn fx:id="colAcoes" prefWidth="240.0" text="Mudar Status" />
        </columns>
    </TableView>

    <Button onAction="#handleFechar" maxWidth="Infinity" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-cursor: hand;" text="Fechar Janela" />
</VBox>