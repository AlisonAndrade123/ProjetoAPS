<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane style="-fx-background-color: #F0F2F5;" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="br.edu.ifpb.lojavirtual.controller.PagamentoController">
    <children>
        <VBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
              AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <HBox alignment="CENTER" spacing="30.0">
                    <children>
                        <!-- Painel de Opções de Pagamento -->
                        <VBox fx:id="paymentOptionsVBox" spacing="20.0" HBox.hgrow="ALWAYS" maxWidth="500">
                            <children>
                                <Label text="Como você prefere pagar?" fx:id="tituloLabel" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

                                <HBox fx:id="opcoesPagamentoHBox" spacing="10.0" alignment="CENTER_LEFT"/>

                                <StackPane fx:id="painelMetodoPagamento" alignment="TOP_LEFT"
                                           style="-fx-border-color: #E0E0E0; -fx-background-color: white; -fx-border-radius: 8; -fx-background-radius: 8;"
                                           minHeight="280.0">
                                </StackPane>
                            </children>
                        </VBox>

                        <!-- Painel de Resumo do Pedido -->
                        <VBox fx:id="resumoVBox" spacing="15.0" minWidth="350.0" prefWidth="350.0">
                            <children>
                                <Label fx:id="resumoTituloLabel" text="RESUMO DO PEDIDO" style="-fx-font-weight: bold;"/>
                                <Separator prefWidth="200.0"/>
                                <HBox>
                                    <children>
                                        <Label text="Subtotal:"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="subtotalLabel" text="R$ 0,00"/>
                                    </children>
                                </HBox>
                                <HBox>
                                    <children>
                                        <Label text="Frete:"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="freteLabel" text="R$ 0,00"/>
                                    </children>
                                </HBox>
                                <Separator prefWidth="200.0"/>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label fx:id="totalTituloLabel" text="Total:" style="-fx-font-weight: bold;"/>
                                        <Region HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="totalLabel" text="R$ 0,00" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #00A60E;"/>
                                    </children>
                                </HBox>

                                <Region VBox.vgrow="ALWAYS" minHeight="20"/>

                                <!-- Indicador de Carregamento (será controlado via Thread no Controller) -->
                                <VBox fx:id="processamentoBox" alignment="CENTER" managed="false" visible="false" spacing="10">
                                    <children>
                                        <Label text="Processando compra..."/>
                                        <ProgressIndicator prefHeight="40" prefWidth="40"/>
                                    </children>
                                </VBox>

                                <!-- BOTÃO VOLTAR -->
                                <Button fx:id="btnVoltar" onAction="#handleVoltar"
                                        maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                        text="Voltar ao Carrinho"
                                        style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 10;"/>

                                <!-- BOTÃO PAGAR -->
                                <Button fx:id="confirmarPagamentoButton" onAction="#handleConfirmarPagamento"
                                        maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                        text="Confirmar Pagamento"
                                        style="-fx-background-color: #00A60E; -fx-text-fill: white; -fx-cursor: hand; -fx-font-weight: bold; -fx-padding: 12;"/>
                            </children>
                        </VBox>
                    </children>
                    <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
                    </padding>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>